# Supabase
# Erstelle ein Projekt auf https://supabase.com und trage die Werte ein.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_TELEMETRY_ENABLED=true

# Local scripts only (never expose in client code)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth ohne E-Mail-Limit (empfohlen fuer Entwicklung):
# Supabase Free Tier: nur 2-3 E-Mails/Stunde. Bei "Confirm email" AN
# wird jede Registrierung eine E-Mail verschicken -> schnell Limit erreicht.
# Im Dashboard: Authentication -> Providers -> Email -> "Confirm email" AUS.
# Dann: keine Bestaetigungs-Mail, kein Rate-Limit, Login direkt nach Registrierung.
