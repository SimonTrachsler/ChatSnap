{
  "expo": {
    "name": "ChatSnap",
    "slug": "ChatSnap",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "chatsnap",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "package": "com.chatsnap.app",
      "permissions": [
        "CAMERA"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chatsnap.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Die App benoetigt Kamerazugriff, um Fotos aufzunehmen."
        }
      ]
    ]
  }
}
